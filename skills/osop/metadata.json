{
  "name": "osop",
  "version": "1.0.0",
  "description": "OSOP workflow authoring, validation, risk analysis, and self-optimization for AI agents.",
  "author": "osop",
  "license": "Apache-2.0",
  "homepage": "https://osop.ai",
  "repository": "https://github.com/Archie0125/osop-skill",
  "skill_file": "SKILL.md",
  "prompts": {
    "system": "../../prompts/system-prompt.md",
    "policy": "../../prompts/policy-pack.md"
  },
  "mcp": {
    "server_name": "osop",
    "url_env": "OSOP_MCP_URL",
    "tools": [
      "osop.validate",
      "osop.risk_assess",
      "osop.run",
      "osop.render",
      "osop.test",
      "osop.optimize",
      "osop.import",
      "osop.export",
      "osop.report"
    ]
  },
  "env_gating": {
    "required": [
      {
        "name": "OSOP_MCP_URL",
        "description": "URL of the OSOP MCP server. The skill will not activate unless this is set.",
        "example": "http://localhost:8080"
      }
    ],
    "optional": [
      {
        "name": "OSOP_APPROVAL_MODE",
        "description": "Controls approval gate behavior. 'auto' skips human approval, 'manual' requires it.",
        "default": "manual",
        "allowed_values": ["auto", "manual"]
      }
    ]
  },
  "tags": ["workflow", "automation", "sop", "process", "devops", "ci-cd", "risk-analysis"],
  "compatibility": {
    "openclaw": ">=0.1.0"
  }
}
